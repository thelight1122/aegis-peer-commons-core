{
    "name": "aegis-core-shield",
    "version": "0.1.0",
    "description": "Non-force governance layer for OpenClaw agents - Discernment Gate + Virtue Integrity System",
    "main": "dist/main/main.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\" \"npm run prime\" \"run-s wait-dev dev:electron\"",
        "dev:full": "npm run dev",
        "wait-dev": "wait-on http://localhost:3000",
        "dev:electron": "cross-env NODE_ENV=development electron .",
        "dev:renderer": "vite",
        "dev:main": "tsc -w -p tsconfig.json",
        "prime": "ts-node src/cli/mirror-prime.ts",
        "gui": "run-s build open:electron",
        "open:electron": "electron .",
        "build": "run-s build:main build:renderer",
        "build:main": "tsc",
        "build:renderer": "vite build",
        "gate": "ts-node src/cli/index.ts",
        "test": "jest",
        "test:watch": "jest --watch",
        "clean": "rimraf dist",
        "typecheck": "tsc --noEmit",
        "steward": "ts-node src/cli/steward-server.ts"
    },
    "keywords": [
        "aegis",
        "governance",
        "discernment",
        "virtue",
        "integrity",
        "openclaw"
    ],
    "author": "AEGIS Core Team",
    "license": "MIT",
    "devDependencies": {
        "@types/better-sqlite3": "^7.6.13",
        "@types/jest": "^29.5.11",
        "@types/node": "^20.19.32",
        "@types/react": "^19.2.13",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^5.1.4",
        "concurrently": "^9.2.1",
        "cross-env": "^10.1.0",
        "electron": "^40.6.1",
        "jest": "^29.7.0",
        "npm-run-all": "^4.1.5",
        "rimraf": "^5.0.5",
        "ts-jest": "^29.1.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3",
        "vite": "^7.3.1",
        "wait-on": "^9.0.4"
    },
    "dependencies": {
        "@monaco-editor/react": "^4.7.0",
        "better-sqlite3": "^11.10.0",
        "full": "^1.0.1",
        "kill-port": "^2.0.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "jest": {
        "preset": "ts-jest",
        "testEnvironment": "node",
        "roots": [
            "<rootDir>/src"
        ],
        "testMatch": [
            "**/__tests__/**/*.ts",
            "**/?(*.)+(spec|test).ts"
        ],
        "collectCoverageFrom": [
            "src/**/*.ts",
            "!src/**/*.test.ts",
            "!src/**/*.d.ts"
        ]
    }
}
